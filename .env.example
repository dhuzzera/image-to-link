# ============================================
# Configuração do Image to Link
# Copie este arquivo para .env e preencha os valores
# ============================================

# Banco de dados (Supabase PostgreSQL)
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Autenticação
JWT_SECRET=sua-chave-secreta-aqui
VITE_APP_ID=seu-app-id
OAUTH_SERVER_URL=https://seu-oauth-server.com
VITE_OAUTH_PORTAL_URL=https://seu-portal-oauth.com
OWNER_OPEN_ID=seu-open-id-de-admin

# Storage (S3 / Supabase Storage)
BUILT_IN_FORGE_API_URL=https://sua-api-storage.com
BUILT_IN_FORGE_API_KEY=sua-chave-storage

# Servidor
PORT=3000
NODE_ENV=development
