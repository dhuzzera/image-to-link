# Supabase
VITE_SUPABASE_URL=https://zppvivlnjuhqrrczwjhr.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Banco de dados (Supabase PostgreSQL)
